rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // REGLAS DE SEGURIDAD — Requieren autenticación con restricciones de rol
    // =====================================================================

    // Emergencias — lectura para usuarios autenticados, creación con vecinoId propio
    match /emergencias/{emergenciaId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.vecinoId == request.auth.uid;
      // S5 FIX: Solo el patrullero asignado o el sistema pueden actualizar
      allow update: if request.auth != null
                    && (
                      // El patrullero asignado puede actualizar estado
                      resource.data.patrullaAsignadaId == request.auth.uid
                      // O el vecino que creó la emergencia puede actualizar su ubicación actual
                      || resource.data.vecinoId == request.auth.uid
                      // P1: Operador C3 puede gestionar emergencias de su tipo o todas si es ADMIN
                      || (exists(/databases/$(database)/documents/operadores_c3/$(request.auth.uid)) 
                          && (
                            get(/databases/$(database)/documents/operadores_c3/$(request.auth.uid)).data.rol == 'ADMIN' ||
                            get(/databases/$(database)/documents/operadores_c3/$(request.auth.uid)).data.rol == resource.data.tipo
                          ))
                    );
      allow delete: if false;
    }

    // S4 FIX: Patrulleros — lectura pública (para el mapa público), escritura solo para el propio patrullero
    match /patrulleros/{uid} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid;
    }

    // Enlaces Públicos — lectura pública (para verificar token), escritura solo ADMIN
    match /enlaces_publicos/{tokenId} {
      allow read: if true;
      allow write: if request.auth != null 
                   && exists(/databases/$(database)/documents/operadores_c3/$(request.auth.uid))
                   && get(/databases/$(database)/documents/operadores_c3/$(request.auth.uid)).data.rol == 'ADMIN';
    }

    // Usuarios — lectura autenticada, creación libre (registro), update solo propietario
    match /usuarios/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                        || resource.data.dni == docId);
      allow delete: if false;
    }

    // Operadores C3 — solo lectura para verificación de rol
    match /operadores_c3/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Auditoría — solo lectura, Cloud Functions escriben con Admin SDK
    match /auditoria/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
